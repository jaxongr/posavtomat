{
  "name": "savdo-pos",
  "version": "0.0.0",
  "private": true,
  "description": "SAVDO-POS — Do'kon & Restoran avtomatlashtirish platformasi (multi-tenant POS)",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:backend": "pnpm --filter @savdo-pos/backend start:dev",
    "dev:admin": "pnpm --filter @savdo-pos/admin dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:up": "docker compose up -d postgres redis",
    "db:migrate": "pnpm --filter @savdo-pos/backend prisma:migrate",
    "db:seed": "pnpm --filter @savdo-pos/backend prisma:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.6",
    "prettier": "^3.3.3"
  }
}
