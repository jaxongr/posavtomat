# ─────────────────────────── CORE ───────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ─────────────────────────── DATABASE ───────────────────────────
POSTGRES_USER=savdo
POSTGRES_PASSWORD=savdo
POSTGRES_DB=savdo_pos
POSTGRES_PORT=5432
DATABASE_URL=postgresql://savdo:savdo@localhost:5432/savdo_pos?schema=public

# ─────────────────────────── REDIS ───────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─────────────────────────── AUTH ───────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Field-level encryption (pinHash pepper, sensitive fields)
ENCRYPTION_KEY=change_me_32_byte_key____________

# ─────────────────────────── MONEY / LOCALE ───────────────────────────
DEFAULT_CURRENCY=UZS

# ─────────────────────────── PRINTING ───────────────────────────
# ESC/POS printer gateway (chek + KOT). Skelet bosqichida ishlatilmaydi.
PRINTER_GATEWAY_URL=

# ─────────────────── PAYMENTS (7-bosqich — hozir bo'sh) ───────────────────
PAYME_MERCHANT_ID=
PAYME_KEY=
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET=
UZUM_MERCHANT_ID=
UZUM_SECRET=

# ─────────────────── FISCAL (hozircha o'chiq — abstraksiya tayyor) ───────────────────
FISCAL_PROVIDER_URL=
FISCAL_TOKEN=

# ─────────────────────────── MONITORING ───────────────────────────
SENTRY_DSN=
LOG_LEVEL=debug
